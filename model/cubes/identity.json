    "categories": [
      {
        "groups": [
          "analyst",
          "admin",
          "marketing",
          "regional_lead"
        ],
        "member_level": {
          "includes": "*"
        }
      }
    ],
    "merchants": [
      {
        "groups": [
          "analyst",
          "admin",
          "marketing",
          "regional_lead"
        ],
        "member_level": {
          "includes": "*"
        }
      }
    ],
    "transactions": [
      {
        "groups": [
          "analyst",
          "admin"
        ],
        "member_level": {
          "includes": "*"
        }
      },
      {
        "group": "customer",
        "conditions": [
          {
            "if": "{ securityContext.user_id }"
          }
        ],
        "row_level": {
          "filters": [
            {
              "member": "user_id",
              "operator": "equals",
              "values": [
                "{ securityContext.user_id }"
              ]
            }
          ]
        },
        "member_level": {
          "includes": [
            "id",
            "user_id",
            "account_id",
            "merchant_id",
            "category_id",
            "amount",
            "description",
            "status",
            "transaction_date",
            "created_at",
            "direction",
            "amount_band",
            "is_posted",
            "count",
            "posted_count",
            "pending_count",
            "failed_count",
            "total_amount",
            "total_expense",
            "net_cashflow",
            "avg_transaction_amount",
            "avg_expense",
            "trailing_30d_expense",
            "trailing_7d_expense",
