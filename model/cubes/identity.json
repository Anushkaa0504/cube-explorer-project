  "roles": {
    "analyst": {
      "description": "Full access to the semantic layer (no masking).",
      "cubes": [
        "users",
        "accounts",
        "categories",
        "merchants",
        "transactions"
      ],
      "access": "full on all cubes with access_policy"
    },
    "admin": {
      "description": "Same cube access as analyst in this demo.",
      "cubes": [
        "users",
        "accounts",
        "categories",
        "merchants",
        "transactions"
      ],
      "access": "full (grouped with analyst in access_policy)"
    },
    "customer": {
      "description": "Own transactions only; PII masked on users and accounts.",
      "cubes": [
        "users",
        "accounts",
        "transactions"
      ],
      "access": "row-level on transactions; limited members + masking on users/accounts"
    },
    "premium_customer": {
      "description": "Like customer but may see income/savings measures (unmasked); own rows only.",
      "cubes": [
        "users",
        "accounts",
        "transactions"
      ],
      "access": "row-level on transactions; income measures not masked"
    },
    "support_agent": {
      "description": "Cross-user support; contact fields and descriptions masked.",
      "cubes": [
        "users",
        "accounts",
        "transactions"
      ],
      "access": "see all rows; mask email/country/name/description where defined"
    },
    "auditor": {
      "description": "Financial review; identity and free-text fields masked.",
      "cubes": [
        "users",
        "accounts",
        "transactions"
      ],
      "access": "aggregates visible; mask identity and descriptions"
    },
    "marketing": {
      "description": "Category/merchant taxonomy + anonymized user list; no money movement cubes.",
      "cubes": [
        "users",
        "categories",
        "merchants"
      ],
      "access": "users PII masked; no accounts or transactions"
    },
    "finance_viewer": {
      "description": "Global transaction aggregates only \u2014 no dimensions or descriptions.",
      "cubes": [
        "transactions"
      ],
      "access": "measures-only on transactions"
    },
    "regional_lead": {
      "description": "Users and spend in one country (JWT country); account names masked.",
      "cubes": [
        "users",
        "accounts",
        "transactions"
      ],
      "access": "row filter by users.country; mask contact fields"
    }
  },
  "accessPolicies": {
    "users": [
      {
        "groups": [
          "analyst",
          "admin"
        ],
        "member_level": {
          "includes": "*"
        }
      },
      {
        "group": "customer",
        "member_level": {
          "includes": [
            "id",
            "full_name",
            "created_at",
            "count"
          ]
        },
        "member_masking": {
          "includes": [
            "email",
            "country"
          ]
        }
      },
      {
        "group": "premium_customer",
        "member_level": {
          "includes": [
            "id",
            "full_name",
            "created_at",
            "count"
          ]
        },
        "member_masking": {
          "includes": [
            "email",
            "country"
          ]
        }
      },
      {
        "group": "support_agent",
        "member_level": {
          "includes": [
            "id",
            "full_name",
            "created_at",
            "count"
          ]
        },
        "member_masking": {
          "includes": [
            "email",
            "country"
          ]
        }
      },
      {
        "group": "regional_lead",
        "member_level": {
          "includes": [
            "id",
            "full_name",
            "created_at",
            "count",
            "country"
          ]
        },
        "member_masking": {
          "includes": [
            "email"
          ]
        }
      },
      {
        "group": "marketing",
        "member_level": {
          "includes": [
            "id",
            "full_name",
            "created_at",
            "count"
          ]
        },
        "member_masking": {
          "includes": [
            "email",
            "country"
          ]
        }
      },
      {
        "group": "finance_viewer",
        "member_level": {
          "includes": [
            "count"
          ]
        }
      },
      {
        "group": "auditor",
        "member_level": {
          "includes": [
            "id",
            "created_at",
            "count"
          ]
        },
        "member_masking": {
          "includes": [
            "email",
            "full_name",
            "country"
          ]
        }
      }
    ],
    "accounts": [
      {
        "groups": [
          "analyst",
          "admin"
        ],
        "member_level": {
          "includes": "*"
        }
      },
      {
        "group": "customer",
