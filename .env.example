# ---------------------------------------------------------------------------
# Cube Core – environment variables
# Full reference: https://cube.dev/docs/reference/configuration/environment-variables
# ---------------------------------------------------------------------------
# Copy to .env and edit as needed. The defaults below connect Cube to the
# locally-seeded personal-finance Postgres started by docker-compose.

CUBEJS_DEV_MODE=true
CUBEJS_LOG_LEVEL=info
CUBEJS_PG_SQL_PORT=15432
CUBEJS_API_SECRET=super-secret-please-change-me
# System/orchestration JWT signing (optional; scripts/sign_jwt.py --system)
CUBEJS_PLAYGROUND_AUTH_SECRET=system-secret-please-change-me

# Local Postgres seeded from `seed/*.sql`.
CUBEJS_DB_TYPE=postgres
CUBEJS_DB_HOST=localhost
CUBEJS_DB_PORT=5435
CUBEJS_DB_NAME=finance
CUBEJS_DB_USER=cube
CUBEJS_DB_PASS=cube

CUBEJS_CUBESTORE_HOST=localhost
CUBEJS_CUBESTORE_PORT=3030

CUBEJS_SCHEMA_PATH=model

CUBEJS_SQL_USER=cube
CUBEJS_SQL_PASSWORD=cube
